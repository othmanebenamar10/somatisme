# Configuration Email pour le formulaire de contact
# Copiez ce fichier en .env et remplissez les valeurs

# Configuration SMTP (pour Gmail ou autre service email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre_email@gmail.com
SMTP_PASS=votre_mot_de_passe_ou_app_password

# Email d'envoi et de réception
EMAIL_FROM="SOMATISME" <votre_email@gmail.com>
EMAIL_TO=info@somatisme.ma

# Pour Gmail, vous devez utiliser un "App Password" :
# 1. Allez dans les paramètres de votre compte Google
# 2. Activez la "vérification en 2 étapes"
# 3. Générez un "Mot de passe d'application"
# 4. Utilisez ce mot de passe d'application comme SMTP_PASS

# Configuration MongoDB Atlas (Base de données sécurisée)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/somatisme?retryWrites=true&w=majority

# Sécurité IP (Liste blanche et liste noire)
TRUSTED_IPS=1.2.3.4,5.6.7.8
BLOCKED_IPS=

# Pour MongoDB Atlas :
# 1. Créez un compte sur https://www.mongodb.com/cloud/atlas
# 2. Créez un nouveau cluster (choisissez M0 gratuit pour le développement)
# 3. Dans "Security", créez un utilisateur avec "Read and write to any database"
# 4. Dans "Network Access", ajoutez l'IP 0.0.0.0/0 pour autoriser tous les accès (ou spécifiez vos IPs)
# 5. Dans "Database Access", activez "Data API" si nécessaire
# 6. Copiez la connection string et remplacez username/password
# 7. Activez "Encryption at Rest" et "TLS" dans les paramètres du cluster
# 8. Configurez "IP Whitelist" pour restreindre l'accès
